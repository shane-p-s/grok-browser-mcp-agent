# --- Grok connector auth (server expects: Authorization: Bearer <AUTH_TOKEN>) ---
AUTH_TOKEN=generate-a-long-random-secret

# Bind MCP + health (recommended behind Funnel: localhost only)
HOST=127.0.0.1
PORT=8765

# --- Browser automation (Browser Use -> DeepSeek) ---
DEEPSEEK_API_KEY=
# Default fast model and optional "reasoner" when browser_task use_reasoner=true
BROWSER_USE_LLM_MODEL=deepseek-chat
BROWSER_USE_LLM_MODEL_DEEP=deepseek-reasoner
# Default headed when headed=null: per-domain memory (if any) else this flag (default false = headless-first)
BROWSER_HEADED=false

# --- Cursor Agent CLI (https://cursor.com/docs/cli/headless) ---
CURSOR_API_KEY=
# Semicolon-separated absolute dirs on Windows, e.g. C:\Code\repo1;C:\Code\repo2
CURSOR_WORKSPACE_ROOTS=
# Optional: full path to agent.exe if not on PATH
# CURSOR_AGENT_PATH=
CURSOR_AGENT_TIMEOUT_SECONDS=900
CURSOR_AGENT_MAX_OUTPUT_CHARS=120000

# --- Local encrypted secrets (optional; never sent to DeepSeek in browser_task when using secret_prefill) ---
# Fernet key (urlsafe base64). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRETS_MASTER_KEY=
# Optional override path (default: %LOCALAPPDATA%\grok-mcp-agent\secrets.enc.json on Windows)
# SECRETS_STORE_PATH=

# --- Optional GitHub REST (contents + compare for list/diff tools; issues write for create_issue) ---
GITHUB_TOKEN=
# Optional caps for GitHub tool responses
# GITHUB_GET_FILE_MAX_CHARS=524288
# GITHUB_LIST_FILES_MAX_PATHS=8000
# GITHUB_GET_DIFF_MAX_CHARS=200000

# MCP: JSON-only (default) vs SSE-friendly
MCP_JSON_RESPONSE=true

# Comma-separated tool names to reject at call time (e.g. browser_task,cursor_agent). get_status is never disabled.
# MCP_DISABLED_TOOLS=

# Persistent approvals / browser prefs (JSON). Default: %LOCALAPPDATA%\grok-mcp-agent\memory.json
# AGENT_MEMORY_PATH=

# Playwright persistent profile dir for browser_task (cookies across runs). Optional.
# BROWSER_USER_DATA_DIR=%LOCALAPPDATA%\grok-mcp-agent\browser-profile

FETCH_MAX_BYTES=2000000
BROWSER_TASK_TIMEOUT_SECONDS=300
BROWSER_TASK_MAX_STEPS=40

LOG_LEVEL=INFO

# --- Run logs (browser_task / cursor_agent); optional JSONL on disk ---
AGENT_LOG_ENABLE_DISK=false
# AGENT_LOG_DIR=%LOCALAPPDATA%\grok-mcp-agent\logs
# When true, append redacted NDJSON lines to AGENT_LOG_DIR/agent_events.ndjson
AGENT_LOG_MAX_EVENTS_PER_RUN=200
AGENT_LOG_RETAIN_RUNS=50
AGENT_LOG_MAX_RESPONSE_CHARS=96000

# Fail startup if AUTH_TOKEN missing when K_SERVICE (Cloud Run) or ENVIRONMENT=production
# ENVIRONMENT=production
