# --- Grok connector auth ---
# Option A — static Bearer (smoke tests, simple clients): set AUTH_TOKEN.
AUTH_TOKEN=generate-a-long-random-secret
#
# Option B — OAuth for Grok "Custom Connector" (PKCE + JWT access tokens). Uncomment and set OAUTH_*.
# OAUTH_ENABLED=true
# OAUTH_CLIENT_ID=grok-pc-mcp
# OAUTH_CLIENT_SECRET=
# OAUTH_JWT_SECRET=generate-a-long-random-secret-different-from-AUTH_TOKEN
# Comma-separated host suffixes for https redirect_uri (Grok may use grok.com; xAI APIs use .x.ai).
# OAUTH_REDIRECT_URI_HOST_SUFFIX=.x.ai,.grok.com
# OAUTH_ACCESS_TOKEN_TTL_SECONDS=7776000

# Bind MCP + health (recommended behind Funnel: localhost only)
HOST=127.0.0.1
PORT=8765
# Tray: skip auto-building Grok-PC-MCP.exe on first start (default builds for taskbar pin)
# GROK_TRAY_NO_AUTO_EXE=1
#
# MCP Streamable HTTP (python-sdk) validates Host when bound to localhost. Behind Tailscale Funnel the Host is
# your *.ts.net name — without this, Grok gets HTTP 421 on POST /mcp/. Comma-separated hostnames (https:// optional).
# MCP_EXTRA_ALLOWED_HOSTS=your-machine.tail1234.ts.net
# Or turn off DNS rebinding checks entirely (not recommended on untrusted networks):
# MCP_DNS_REBINDING_PROTECTION=false

# --- Browser automation (Browser Use -> DeepSeek) ---
DEEPSEEK_API_KEY=
# Optional. OpenAI-compatible base URL including /v1 (browser_use ChatDeepSeek). Default: https://api.deepseek.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Default fast model and optional "reasoner" when browser_task use_reasoner=true
BROWSER_USE_LLM_MODEL=deepseek-chat
BROWSER_USE_LLM_MODEL_DEEP=deepseek-reasoner
# Default headed when headed=null: per-domain memory (if any) else this flag (default false = headless-first)
BROWSER_HEADED=false
# HTTPS origin clients use to reach this host (same as Funnel, no path). Enables one-time GET /browser-screenshot/{token} so tool JSON stays small (no inline base64).
# PUBLIC_MCP_BASE_URL=https://your-machine.tail1234.ts.net
# Require the same Bearer as /mcp/ when fetching a screenshot URL (opaque URL token alone is not enough)
# BROWSER_SCREENSHOT_REQUIRE_BEARER=true
# BROWSER_SCREENSHOT_URL_TTL_SECONDS=600
# BROWSER_SCREENSHOT_MAX_BYTES=12000000
# Optional early downscale when raw PNG exceeds this byte size (0 = off; default keeps full CDP quality until MAX_BYTES)
# BROWSER_SCREENSHOT_DOWNSCALE_IF_RAW_BYTES_LARGER_THAN=0
# Max edge when downscaling (only when PNG exceeds BROWSER_SCREENSHOT_MAX_BYTES or optional threshold above)
# BROWSER_SCREENSHOT_MAX_EDGE=1920
# Max concurrent browser_task agents on separate tabs (same Chrome window)
# BROWSER_TASK_MAX_CONCURRENT=3
# Max interactive elements returned by browser_get_page_state (default 80)
# BROWSER_PAGE_STATE_MAX_ELEMENTS=80
# browser_open_tab: reuse idle tab when tab_label matches (default true in tool; no env needed)
# browser_task: when continue_tab_id omitted, match tab_label to idle tab (default false)
# BROWSER_AUTO_CONTINUE_TAB_BY_LABEL=false
# Watch Mode: background viewport captures; poll GET /browser-watch/{watch_id}/latest (reusable PNG)
# BROWSER_WATCH_MAX_DURATION_SECONDS=30
# BROWSER_WATCH_DEFAULT_INTERVAL_SECONDS=2
# BROWSER_WATCH_MAX_HISTORY_FRAMES=10
# BROWSER_WATCH_HTTP_GRACE_SECONDS=30

# --- Cursor Agent CLI (https://cursor.com/docs/cli/headless) ---
CURSOR_API_KEY=
# Semicolon-separated absolute dirs on Windows, e.g. C:\Code\repo1;C:\Code\repo2
CURSOR_WORKSPACE_ROOTS=
# Optional: full path to agent.exe if not on PATH
# CURSOR_AGENT_PATH=
CURSOR_AGENT_TIMEOUT_SECONDS=900
CURSOR_AGENT_MAX_OUTPUT_CHARS=120000

# --- Local encrypted secrets (optional; never sent to DeepSeek in browser_task when using secret_prefill) ---
# Fernet key (urlsafe base64). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRETS_MASTER_KEY=
# Optional override path (default: %LOCALAPPDATA%\grok-mcp-agent\secrets.enc.json on Windows)
# SECRETS_STORE_PATH=

# --- Optional GitHub REST (contents + compare for list/diff tools; issues write for create_issue) ---
GITHUB_TOKEN=
# Optional caps for GitHub tool responses
# GITHUB_GET_FILE_MAX_CHARS=524288
# GITHUB_LIST_FILES_MAX_PATHS=8000
# GITHUB_GET_DIFF_MAX_CHARS=200000

# MCP: JSON-only (default) vs SSE-friendly
MCP_JSON_RESPONSE=true

# Comma-separated tool names to reject at call time (e.g. browser_task,cursor_agent). get_status is never disabled.
# MCP_DISABLED_TOOLS=

# Persistent approvals / browser prefs (JSON). Default: %LOCALAPPDATA%\grok-mcp-agent\memory.json
# AGENT_MEMORY_PATH=

# Playwright persistent profile dir for browser_task (cookies across runs). Optional.
# BROWSER_USER_DATA_DIR=%LOCALAPPDATA%\grok-mcp-agent\browser-profile

FETCH_MAX_BYTES=2000000
BROWSER_TASK_TIMEOUT_SECONDS=300
BROWSER_TASK_MAX_STEPS=40
# Remote MCP clients (e.g. Grok rmcp) may fail on huge tools/call JSON — max length of browser_task `task` (0 = no limit)
# BROWSER_TASK_MAX_INCOMING_TASK_CHARS=65536
# Max serialized size of final_result in browser_task success JSON (larger → truncated + final_result_truncated)
# BROWSER_TASK_MAX_FINAL_RESULT_CHARS=16000

# Fail /health/live with 503 if heartbeat older than this (seconds)
# HEALTH_LIVE_MAX_STALE_SECONDS=15

LOG_LEVEL=INFO

# --- Omi wearable (omi_api_key via request_user_secret, not env) ---
# OMI_API_BASE=https://api.omi.me/v1/dev
# OMI_RECALL_DEFAULT_DAYS=14
# OMI_SYNC_DEFAULT_DAYS=30
# OMI_SYNC_INTERVAL_HOURS=6
# OMI_INDEX_READY_MAX_AGE_HOURS=24
# OMI_MAX_RESPONSE_CHARS=32000
# OMI_MAX_EXCERPT_CHARS=8000
# OMI_CHROMA_PATH=%LOCALAPPDATA%\grok-mcp-agent\omi_chroma

# --- Run logs (browser_task / cursor_agent); optional JSONL on disk ---
AGENT_LOG_ENABLE_DISK=false
# AGENT_LOG_DIR=%LOCALAPPDATA%\grok-mcp-agent\logs
# When true, append redacted NDJSON lines to AGENT_LOG_DIR/agent_events.ndjson
AGENT_LOG_MAX_EVENTS_PER_RUN=200
AGENT_LOG_RETAIN_RUNS=50
AGENT_LOG_MAX_RESPONSE_CHARS=96000

# Fail startup if AUTH_TOKEN missing when K_SERVICE (Cloud Run) or ENVIRONMENT=production
# ENVIRONMENT=production
